+        workers_llm = ChatAnthropic(model_name="claude-sonnet-4-6", timeout=120, stop=None, max_retries=10)
+        formatter_llm = ChatAnthropic(model_name="claude-haiku-4-5", timeout=60, stop=None, max_retries=10)
+        return supervisor_llm, workers_llm, formatter_llm
