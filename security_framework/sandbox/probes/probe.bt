// chanever/agent_security_framework — agent_mds-derived bpftrace probe.
//
// Emits JSONL events to be consumed by trace_parser.parse_bpftrace_trace().
// All five probes are cgroup-scoped via __CGROUP_ID__ substitution so a single
// host-side bpftrace process can observe one sandbox container without
// catching unrelated host activity.
//
//   - process_execve : tracepoint:syscalls:sys_enter_execve  (pre-exec argv —
//                                                              feeds the artifact-anchor
//                                                              attribution rule; argv may
//                                                              carry /workspace/... even when
//                                                              args->filename is the
//                                                              interpreter)
//   - process_exec   : tracepoint:sched:sched_process_exec    (post-exec comm + uid)
//   - process_fork   : tracepoint:sched:sched_process_fork    (ppid → pid edges)
//   - network_egress : tracepoint:sock:inet_sock_set_state    (TCP_SYN_SENT, IPv4)
//   - file_open      : kprobe:security_file_open              (LSM hook function;
//                                                              fires on every open
//                                                              regardless of BPF-LSM
//                                                              build availability)
//   - sentinel       : tracepoint:syscalls:sys_enter_write    (host-driven readiness
//                                                              handshake; the loader
//                                                              writes one byte and waits
//                                                              for this record before
//                                                              releasing the container)
//
// Portability notes (validated on Ubuntu 5.15 + bpftrace v0.19 docker image):
//   - kprobe:tcp_connect is inlined on this kernel; the inet_sock_set_state
//     tracepoint is a stable ABI alternative with daddr/dport already in
//     host byte order.
//   - lsm:file_open requires bpftrace LSM-probe build support that the
//     official iovisor v0.19 image omits. kprobe:security_file_open attaches
//     to the same LSM hook function and yields equivalent observation
//     telemetry (kprobe is observation-only; BPF-LSM enforcement is a
//     follow-up).
//
// The Python loader templates __CGROUP_ID__, __SENTINEL_PID__, and
// __SENTINEL_FD__ before invoking bpftrace, then blocks on the "Attaching N
// probes" stderr marker AND a sentinel_ready event before allowing the
// container to make progress.

BEGIN { printf("{\"type\":\"begin\",\"ts\":%llu}\n", nsecs); }

tracepoint:syscalls:sys_enter_execve / cgroup == __CGROUP_ID__ /
{
  printf("{\"type\":\"process_execve\",\"pid\":%d,\"comm\":\"%s\",\"filename\":\"%s\",\"argv\":\"%s %s %s\",\"ts\":%llu}\n",
         pid, comm, str(args->filename),
         str(args->argv[0]), str(args->argv[1]), str(args->argv[2]),
         nsecs);
}

tracepoint:sched:sched_process_exec / cgroup == __CGROUP_ID__ /
{
  printf("{\"type\":\"process_exec\",\"pid\":%d,\"ppid\":%d,\"comm\":\"%s\",\"uid\":%d,\"ts\":%llu}\n",
         pid, curtask->real_parent->pid, comm, uid, nsecs);
}

tracepoint:sched:sched_process_fork / cgroup == __CGROUP_ID__ /
{
  printf("{\"type\":\"process_fork\",\"ppid\":%d,\"pid\":%d,\"ts\":%llu}\n",
         args->parent_pid, args->child_pid, nsecs);
}

tracepoint:sock:inet_sock_set_state / cgroup == __CGROUP_ID__ && args->newstate == 2 && args->family == 2 /
{
  printf("{\"type\":\"network_egress\",\"pid\":%d,\"comm\":\"%s\",\"destination\":\"%s:%d\",\"ts\":%llu}\n",
         pid, comm, ntop(2, args->daddr), args->dport, nsecs);
}

kprobe:security_file_open / cgroup == __CGROUP_ID__ /
{
  $f = (struct file *)arg0;
  printf("{\"type\":\"file_open\",\"pid\":%d,\"comm\":\"%s\",\"path\":\"%s\",\"ts\":%llu}\n",
         pid, comm, str($f->f_path.dentry->d_name.name), nsecs);
}

tracepoint:syscalls:sys_enter_write / pid == __SENTINEL_PID__ && args->fd == __SENTINEL_FD__ /
{
  printf("{\"type\":\"sentinel_ready\",\"pid\":%d,\"ts\":%llu}\n", pid, nsecs);
}
